// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client"
  output        = "../lib/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum Role {
  ADMIN
  SPV
  USER
}

enum StatusTO {
  PENDING
  DIPROSES
  SELESAI
  DIBATALKAN
}

enum TipeAnomali {
  TURUN_DRASTIS
  STAGNAN
  NOL_PEMAKAIAN
  LONJAKAN
  POLA_TIDAK_WAJAR
}

// ============================================
// MODELS
// ============================================

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  nama      String
  nip       String?  // Nomor Induk Pegawai (opsional)
  jabatan   String?  // Jabatan/posisi (opsional)
  email     String?  // Email (opsional, tidak harus unique)
  role      Role     @default(USER)
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  targetOperasi TargetOperasi[] @relation("CreatedBy")
  logAktivitas  LogAktivitas[]
  importJobs    ImportJob[]

  @@map("users")
}

model Pelanggan {
  id          String   @id @default(cuid())
  idPelanggan String   @unique
  nama        String
  tarif       String
  daya        Int
  lokasi      String
  isToHistory Boolean  @default(false)
  dataLengkap Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pemakaian     Pemakaian[]
  targetOperasi TargetOperasi[]

  // Index untuk filter dashboard: pelanggan tidak lengkap
  @@index([dataLengkap])
  // Index untuk filter isToHistory
  @@index([isToHistory])

  @@map("pelanggan")
}

model Pemakaian {
  id          String   @id @default(cuid())
  pelangganId String
  bulan       Int
  tahun       Int
  kwh         Float
  keterangan  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pelanggan Pelanggan @relation(fields: [pelangganId], references: [id], onDelete: Cascade)

  // Unique sudah berfungsi sebagai index untuk (pelangganId, bulan, tahun)
  @@unique([pelangganId, bulan, tahun])
  // Index tambahan untuk query per tahun (generate TO, grafik)
  @@index([tahun, bulan])
  // Index untuk pencarian semua pemakaian milik satu pelanggan
  @@index([pelangganId])

  @@map("pemakaian")
}

model TargetOperasi {
  id          String      @id @default(cuid())
  pelangganId String
  tipeAnomali TipeAnomali
  alasan      String
  skor        Float
  status      StatusTO    @default(PENDING)
  periode     String
  catatan     String?
  createdById String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  pelanggan Pelanggan @relation(fields: [pelangganId], references: [id], onDelete: Cascade)
  createdBy User      @relation("CreatedBy", fields: [createdById], references: [id])

  // Index untuk filter status (paling sering dipakai di tabel TO)
  @@index([status])
  // Index untuk filter tipe anomali
  @@index([tipeAnomali])
  // Index untuk filter periode
  @@index([periode])
  // Index untuk relasi pelanggan
  @@index([pelangganId])
  // Index untuk laporan (query berdasarkan tanggal dibuat)
  @@index([createdAt])
  // Index gabungan untuk filter status + tipe sekaligus
  @@index([status, tipeAnomali])

  @@map("target_operasi")
}

model Temuan {
  id        String   @id @default(cuid())
  namaPola  String   @unique
  deskripsi String
  kriteria  Json
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("temuan")
}

model LogAktivitas {
  id        String   @id @default(cuid())
  userId    String
  aksi      String
  detail    String?
  ipAddress String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  // Index untuk query log per user
  @@index([userId])
  // Index untuk query log terbaru (notifikasi, audit trail)
  @@index([createdAt])
  // Index gabungan untuk filter userId + createdAt sekaligus
  @@index([userId, createdAt])

  @@map("log_aktivitas")
}

model TOHistoris {
  id            String    @id @default(cuid())
  idPelanggan   String    @unique
  tanggalTemuan DateTime?
  kategori      String?
  createdAt     DateTime  @default(now())

  @@map("to_historis")
}

model ImportJob {
  id          String   @id @default(cuid())
  userId      String
  type        String
  status      String   @default("PENDING")
  total       Int      @default(0)
  processed   Int      @default(0)
  created     Int      @default(0)
  updated     Int      @default(0)
  errors      Int      @default(0)
  errorDetail String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  // Index untuk polling job aktif milik user tertentu
  @@index([userId, status])

  @@map("import_jobs")
}