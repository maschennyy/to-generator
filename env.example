# ============================================================
# NALAR — Environment Variables
# Salin file ini menjadi .env dan isi semua variabel
# ============================================================

# ------------------------------------------------------------
# DATABASE (wajib)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Contoh lokal: postgresql://postgres:password@localhost:5432/to_app_db
# ------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/to_app_db"

# ------------------------------------------------------------
# NEXTAUTH (wajib)
# AUTH_SECRET: string acak minimal 32 karakter
# Generate: openssl rand -base64 32
# ------------------------------------------------------------
AUTH_SECRET="ganti-dengan-string-acak-minimal-32-karakter"

# ------------------------------------------------------------
# UPSTASH REDIS — untuk rate limiting login (wajib)
# Daftar gratis di: https://upstash.com
# Buat database Redis → salin REST URL dan REST Token
# ------------------------------------------------------------
UPSTASH_REDIS_REST_URL="https://xxx-xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxx"

# ------------------------------------------------------------
# NALAR RISK ENGINE (opsional)
# URL FastAPI NALAR service. Jika kosong/mati, aplikasi tetap berjalan
# dan menampilkan "Skor NALAR tidak tersedia".
# Untuk Docker Compose di VPS: http://ml-service:8000
# Untuk development lokal non-Docker: http://localhost:8000
# ------------------------------------------------------------
NALAR_SERVICE_URL="http://localhost:8000"
NALAR_SERVICE_TOKEN="ganti-dengan-token-internal-yang-panjang-dan-acak"
# Alias lama tetap didukung untuk kompatibilitas:
ML_SERVICE_URL="http://localhost:8000"
ML_SERVICE_TOKEN="ganti-dengan-token-internal-yang-panjang-dan-acak"
ML_MAX_F1_DROP="0.05"
ML_MAX_PRECISION_DROP="0.10"
ML_TRAINING_LOCK_KEY="70220260603"
NALAR_TRAINING_STALE_MINUTES="120"

# ------------------------------------------------------------
# NEXTAUTH URL (opsional di development, wajib di production)
# Isi dengan domain production kamu
# Contoh: https://sigtari.vercel.app
# ------------------------------------------------------------
# NEXTAUTH_URL="http://localhost:3000"
